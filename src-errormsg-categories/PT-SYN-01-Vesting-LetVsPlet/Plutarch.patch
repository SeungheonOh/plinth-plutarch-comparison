# source: src/Vesting/Contracts/Vesting.hs
#
# Category: Plutarch - let/plet, ->/:--> mix-up
# Bug: replace a `pletC` (TermCont-flavored binding) with the CPS form
# `plet` while keeping the surrounding `unTermCont $ do { ... }` block
# unchanged. `pletC :: Term s a -> TermCont s (Term s a)`, but
# `plet :: Term s a -> (Term s a -> Term s b) -> Term s b`. The `<-`
# binding therefore expects `TermCont s X` and instead gets the
# CPS continuation type from `plet`, yielding a "couldn't match
# TermCont with `Term s _ -> ...`" diagnostic.
#
# Apply with:
#   cp <repo>/src/Vesting/Contracts/Vesting.hs <case>/Plutarch.hs
#   (cd <case> && patch -p1 < Plutarch.patch)
#
--- a/Plutarch.hs
+++ b/Plutarch.hs
@@ -200,8 +200,8 @@
                 pure $
                   pif
                     (pmustBeSignedBy # pfromData ptxInfo'signatories # beneficiary)
                     ( unTermCont $ do
-                        inputs <- pletC (pfromData ptxInfo'inputs)
-                        outputs <- pletC (pfromData ptxInfo'outputs)
+                        inputs <- plet (pfromData ptxInfo'inputs)
+                        outputs <- plet (pfromData ptxInfo'outputs)
                         PTxInInfo{ptxInInfo'resolved} <-
                           pmatchC (pfindOwnInput # inputs # ownRef)
                         ownResolved <- pletC ptxInInfo'resolved
