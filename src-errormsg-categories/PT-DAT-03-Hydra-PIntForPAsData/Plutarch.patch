# source: src/Hydra/Contracts/Head.hs
#
# Category: Plutarch - PAsData wrap/unwrap confusion
# Bug: drop the `pdata` wrappers around `ref1`/`ref2` before passing them
# to `pforgetData`. `pforgetData :: Term s (PAsData a) :--> Term s PData`,
# so it needs an explicit `PAsData`-wrapped term. Calling
# `pforgetData ref1` where `ref1 :: Term s PTxOutRef` triggers a
# "Couldn't match type `PTxOutRef` with `PAsData _`" diagnostic at both
# call sites in `pcompareRef`.
#
# Apply with:
#   cp <repo>/src/Hydra/Contracts/Head.hs <case>/Plutarch.hs
#   (cd <case> && patch -p1 < Plutarch.patch)
#
--- a/Plutarch.hs
+++ b/Plutarch.hs
@@ -209,8 +209,8 @@
 pcompareRef :: Term s (PTxOutRef :--> PTxOutRef :--> PInteger)
 pcompareRef = phoistAcyclic $ plam $ \ref1 ref2 ->
-  let fields1 = psndBuiltin # (pasConstr # pforgetData (pdata ref1))
-      fields2 = psndBuiltin # (pasConstr # pforgetData (pdata ref2))
+  let fields1 = psndBuiltin # (pasConstr # pforgetData ref1)
+      fields2 = psndBuiltin # (pasConstr # pforgetData ref2)
       -- TxOutRef = Constr 0 [TxId(Constr 0 [bs]), idx]
       -- TxId is Constr 0 [bytestring]
       txId1Data = phead # fields1
